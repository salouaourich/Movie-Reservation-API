# --- App ---
APP_ENV=dev                 # "dev" or "prod" (prod refuses to boot with default SECRET_KEY)

# --- Database ---
DATABASE_URL=postgresql+asyncpg://cinema_user:cinema_pass@db:5432/cinema_db

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT ---
SECRET_KEY=changeme         # MUST be >= 32 chars in prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ISSUER=movie-reservation-api
JWT_AUDIENCE=movie-reservation-clients

# --- Seat holds ---
HOLD_TTL_SECONDS=300

# --- CORS ---
# Comma-separated. Use the frontend's exact origin in prod, e.g.
# CORS_ORIGINS=https://my-frontend.onrender.com
CORS_ORIGINS=*

# --- Rate limits ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_BOOKING=20/minute
RATE_LIMIT_HOLD=30/minute
