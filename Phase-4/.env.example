# Copy to .env (don't commit) and fill in real values.
# SECRET_KEY is the only one that's strictly required — everything else has a default.

# --- Postgres ---
POSTGRES_DB=cinema_db
POSTGRES_USER=cinema_user
POSTGRES_PASSWORD=change-me-strong

# --- API ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-48-byte-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=60
HOLD_TTL_SECONDS=300

JWT_ISSUER=movie-reservation-api
JWT_AUDIENCE=movie-reservation-clients

# Comma-separated. For local prod-parity testing use http://localhost
# For Render use your frontend's onrender.com URL.
CORS_ORIGINS=http://localhost

# --- Rate limits ---
RATE_LIMIT_ENABLED=true
